<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="http://thewatch.io/architecture/2026-03"
           xmlns:twa="http://thewatch.io/architecture/2026-03"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="2.0">

  <!-- ================================================================================== -->
  <!-- ROOT ELEMENTS                                                                       -->
  <!-- ================================================================================== -->

  <!-- Full architecture document -->
  <xs:element name="TheWatchProject" type="twa:TheWatchProjectType">
    <xs:annotation>
      <xs:documentation>Root element representing The Watch enterprise architecture document.</xs:documentation>
    </xs:annotation>
  </xs:element>

  <!-- Functions-only manifest -->
  <xs:element name="FunctionsManifest" type="twa:FunctionsManifestType">
    <xs:annotation>
      <xs:documentation>Standalone manifest of all behavioral elements: handlers, endpoints, jobs, services, domain events.</xs:documentation>
    </xs:annotation>
  </xs:element>

  <!-- UI-only manifest -->
  <xs:element name="UIManifest" type="twa:UIManifestType">
    <xs:annotation>
      <xs:documentation>Standalone manifest of all UI elements: XAML pages, Blazor components, MAUI controls, styles.</xs:documentation>
    </xs:annotation>
  </xs:element>

  <!-- Structure-only manifest -->
  <xs:element name="StructureManifest" type="twa:StructureManifestType">
    <xs:annotation>
      <xs:documentation>Standalone manifest of project structure: solutions, projects, dependencies, layer topology.</xs:documentation>
    </xs:annotation>
  </xs:element>

  <!-- ================================================================================== -->
  <!-- GENERATION METADATA (shared across all manifests)                                   -->
  <!-- ================================================================================== -->

  <xs:complexType name="GenerationMetadataType">
    <xs:annotation>
      <xs:documentation>Metadata about when and how this manifest was generated.</xs:documentation>
    </xs:annotation>
    <xs:attribute name="generator" type="xs:string" use="required"/>
    <xs:attribute name="generatedAt" type="xs:dateTime" use="required"/>
    <xs:attribute name="framework" type="xs:string" use="optional"/>
    <xs:attribute name="sourceRoot" type="xs:string" use="optional"/>
    <xs:attribute name="version" type="xs:string" use="optional"/>
  </xs:complexType>

  <!-- ================================================================================== -->
  <!-- FUNCTIONS MANIFEST TYPES                                                            -->
  <!-- ================================================================================== -->

  <xs:complexType name="FunctionsManifestType">
    <xs:sequence>
      <xs:element name="Metadata" type="twa:GenerationMetadataType" minOccurs="1" maxOccurs="1"/>
      <xs:element name="CommandHandlers" type="twa:HandlersContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="QueryHandlers" type="twa:HandlersContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="NotificationHandlers" type="twa:HandlersContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="ApiEndpoints" type="twa:EndpointsContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="GrpcServices" type="twa:GrpcServicesContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="SignalRHubs" type="twa:SignalRHubsContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="BackgroundJobs" type="twa:BackgroundJobsContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="HostedServices" type="twa:HostedServicesContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="AzureFunctions" type="twa:AzureFunctionsContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="DomainEventHandlers" type="twa:HandlersContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="Validators" type="twa:ValidatorsContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="PipelineBehaviors" type="twa:PipelineBehaviorsContainerType" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="totalFunctions" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="HandlersContainerType">
    <xs:sequence>
      <xs:element name="Handler" type="twa:HandlerType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="HandlerType">
    <xs:sequence>
      <xs:element name="Request" type="twa:TypeReferenceType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="Response" type="twa:TypeReferenceType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="Summary" type="xs:string" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
    <xs:attribute name="sourceFile" type="xs:string" use="optional"/>
    <xs:attribute name="lineNumber" type="xs:integer" use="optional"/>
    <xs:attribute name="project" type="xs:string" use="optional"/>
    <xs:attribute name="layer" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="TypeReferenceType">
    <xs:attribute name="type" type="xs:string" use="required"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="EndpointsContainerType">
    <xs:sequence>
      <xs:element name="EndpointGroup" type="twa:EndpointGroupType" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="Endpoint" type="twa:EndpointType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="EndpointGroupType">
    <xs:sequence>
      <xs:element name="Endpoint" type="twa:EndpointType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="prefix" type="xs:string" use="optional"/>
    <xs:attribute name="sourceFile" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="EndpointType">
    <xs:sequence>
      <xs:element name="Summary" type="xs:string" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
    <xs:attribute name="method" type="twa:HttpMethodType" use="optional"/>
    <xs:attribute name="route" type="xs:string" use="optional"/>
    <xs:attribute name="handler" type="xs:string" use="optional"/>
    <xs:attribute name="sourceFile" type="xs:string" use="optional"/>
    <xs:attribute name="lineNumber" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="GrpcServicesContainerType">
    <xs:sequence>
      <xs:element name="GrpcService" type="twa:GrpcServiceType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="GrpcServiceType">
    <xs:sequence>
      <xs:element name="Method" type="twa:GrpcMethodType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
    <xs:attribute name="sourceFile" type="xs:string" use="optional"/>
    <xs:attribute name="proto" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="GrpcMethodType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="type" type="twa:GrpcMethodKindType" use="optional"/>
    <xs:attribute name="request" type="xs:string" use="optional"/>
    <xs:attribute name="response" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="SignalRHubsContainerType">
    <xs:sequence>
      <xs:element name="Hub" type="twa:SignalRHubType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="SignalRHubType">
    <xs:sequence>
      <xs:element name="HubMethod" type="twa:HubMethodType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="route" type="xs:string" use="optional"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
    <xs:attribute name="sourceFile" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="HubMethodType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="returnType" type="xs:string" use="optional"/>
    <xs:attribute name="lineNumber" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="BackgroundJobsContainerType">
    <xs:sequence>
      <xs:element name="Job" type="twa:BackgroundJobType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="BackgroundJobType">
    <xs:sequence>
      <xs:element name="Summary" type="xs:string" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="schedule" type="xs:string" use="optional"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
    <xs:attribute name="sourceFile" type="xs:string" use="optional"/>
    <xs:attribute name="lineNumber" type="xs:integer" use="optional"/>
    <xs:attribute name="project" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="HostedServicesContainerType">
    <xs:sequence>
      <xs:element name="HostedService" type="twa:HostedServiceType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="HostedServiceType">
    <xs:sequence>
      <xs:element name="Summary" type="xs:string" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
    <xs:attribute name="sourceFile" type="xs:string" use="optional"/>
    <xs:attribute name="lineNumber" type="xs:integer" use="optional"/>
    <xs:attribute name="project" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="AzureFunctionsContainerType">
    <xs:sequence>
      <xs:element name="Function" type="twa:AzureFunctionType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="AzureFunctionType">
    <xs:sequence>
      <xs:element name="Summary" type="xs:string" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="trigger" type="xs:string" use="optional"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
    <xs:attribute name="sourceFile" type="xs:string" use="optional"/>
    <xs:attribute name="lineNumber" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="ValidatorsContainerType">
    <xs:sequence>
      <xs:element name="Validator" type="twa:ValidatorType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="ValidatorType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="validates" type="xs:string" use="optional"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
    <xs:attribute name="sourceFile" type="xs:string" use="optional"/>
    <xs:attribute name="lineNumber" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="PipelineBehaviorsContainerType">
    <xs:sequence>
      <xs:element name="Behavior" type="twa:PipelineBehaviorType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="PipelineBehaviorType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
    <xs:attribute name="sourceFile" type="xs:string" use="optional"/>
    <xs:attribute name="lineNumber" type="xs:integer" use="optional"/>
  </xs:complexType>

  <!-- ================================================================================== -->
  <!-- UI MANIFEST TYPES                                                                   -->
  <!-- ================================================================================== -->

  <xs:complexType name="UIManifestType">
    <xs:sequence>
      <xs:element name="Metadata" type="twa:GenerationMetadataType" minOccurs="1" maxOccurs="1"/>
      <xs:element name="XamlPages" type="twa:XamlPagesContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="XamlControls" type="twa:XamlControlsContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="BlazorComponents" type="twa:BlazorComponentsContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="BlazorPages" type="twa:BlazorPagesContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="ComponentLibraries" type="twa:ComponentLibrariesContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="Styles" type="twa:StylesContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="StaticAssets" type="twa:StaticAssetsContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="ResourceDictionaries" type="twa:ResourceDictionariesContainerType" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="totalComponents" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="XamlPagesContainerType">
    <xs:sequence>
      <xs:element name="Page" type="twa:XamlPageType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="XamlPageType">
    <xs:sequence>
      <xs:element name="Bindings" type="twa:BindingsContainerType" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="xamlFile" type="xs:string" use="optional"/>
    <xs:attribute name="codeBehind" type="xs:string" use="optional"/>
    <xs:attribute name="pageType" type="twa:XamlPageKindType" use="optional"/>
    <xs:attribute name="project" type="xs:string" use="optional"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
    <xs:attribute name="viewModel" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="XamlControlsContainerType">
    <xs:sequence>
      <xs:element name="Control" type="twa:XamlControlType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="XamlControlType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="xamlFile" type="xs:string" use="optional"/>
    <xs:attribute name="codeBehind" type="xs:string" use="optional"/>
    <xs:attribute name="baseType" type="xs:string" use="optional"/>
    <xs:attribute name="project" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="BindingsContainerType">
    <xs:sequence>
      <xs:element name="Binding" type="twa:BindingType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="BindingType">
    <xs:attribute name="property" type="xs:string" use="required"/>
    <xs:attribute name="path" type="xs:string" use="optional"/>
    <xs:attribute name="mode" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="BlazorComponentsContainerType">
    <xs:sequence>
      <xs:element name="Component" type="twa:BlazorComponentType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="BlazorComponentType">
    <xs:sequence>
      <xs:element name="Parameter" type="twa:ComponentParameterType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="razorFile" type="xs:string" use="optional"/>
    <xs:attribute name="codeBehind" type="xs:string" use="optional"/>
    <xs:attribute name="project" type="xs:string" use="optional"/>
    <xs:attribute name="namespace" type="xs:string" use="optional"/>
    <xs:attribute name="inherits" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="ComponentParameterType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="type" type="xs:string" use="optional"/>
    <xs:attribute name="required" type="xs:boolean" use="optional"/>
  </xs:complexType>

  <xs:complexType name="BlazorPagesContainerType">
    <xs:sequence>
      <xs:element name="Page" type="twa:BlazorPageType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="BlazorPageType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="route" type="xs:string" use="optional"/>
    <xs:attribute name="razorFile" type="xs:string" use="optional"/>
    <xs:attribute name="layout" type="xs:string" use="optional"/>
    <xs:attribute name="project" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="ComponentLibrariesContainerType">
    <xs:sequence>
      <xs:element name="Library" type="twa:ComponentLibraryType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="ComponentLibraryType">
    <xs:sequence>
      <xs:element name="Component" type="twa:BlazorComponentType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="technology" type="xs:string" use="optional"/>
    <xs:attribute name="description" type="xs:string" use="optional"/>
    <xs:attribute name="componentCount" type="xs:integer" use="optional"/>
    <xs:attribute name="project" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="StylesContainerType">
    <xs:sequence>
      <xs:element name="StyleFile" type="twa:StyleFileType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="StyleFileType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="path" type="xs:string" use="optional"/>
    <xs:attribute name="type" type="twa:StyleKindType" use="optional"/>
    <xs:attribute name="project" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="StaticAssetsContainerType">
    <xs:sequence>
      <xs:element name="Asset" type="twa:StaticAssetType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="StaticAssetType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="path" type="xs:string" use="optional"/>
    <xs:attribute name="type" type="xs:string" use="optional"/>
    <xs:attribute name="sizeBytes" type="xs:long" use="optional"/>
  </xs:complexType>

  <xs:complexType name="ResourceDictionariesContainerType">
    <xs:sequence>
      <xs:element name="ResourceDictionary" type="twa:ResourceDictionaryType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="ResourceDictionaryType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="xamlFile" type="xs:string" use="optional"/>
    <xs:attribute name="project" type="xs:string" use="optional"/>
    <xs:attribute name="scope" type="xs:string" use="optional"/>
  </xs:complexType>

  <!-- ================================================================================== -->
  <!-- STRUCTURE MANIFEST TYPES                                                            -->
  <!-- ================================================================================== -->

  <xs:complexType name="StructureManifestType">
    <xs:sequence>
      <xs:element name="Metadata" type="twa:GenerationMetadataType" minOccurs="1" maxOccurs="1"/>
      <xs:element name="Solutions" type="twa:SolutionsContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="Layers" type="twa:StructureLayersContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="DependencyGraph" type="twa:DependencyGraphType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="NuGetPackages" type="twa:NuGetPackagesContainerType" minOccurs="0" maxOccurs="1"/>
      <xs:element name="Frameworks" type="twa:FrameworksContainerType" minOccurs="0" maxOccurs="1"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="totalProjects" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="SolutionsContainerType">
    <xs:sequence>
      <xs:element name="Solution" type="twa:SolutionType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="SolutionType">
    <xs:sequence>
      <xs:element name="ProjectRef" type="twa:SolutionProjectRefType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="path" type="xs:string" use="optional"/>
    <xs:attribute name="type" type="twa:SolutionKindType" use="optional"/>
    <xs:attribute name="projectCount" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="SolutionProjectRefType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="path" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="StructureLayersContainerType">
    <xs:sequence>
      <xs:element name="Layer" type="twa:StructureLayerType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="count" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="StructureLayerType">
    <xs:sequence>
      <xs:element name="Project" type="twa:StructureProjectType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="path" type="xs:string" use="optional"/>
    <xs:attribute name="projectCount" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="StructureProjectType">
    <xs:sequence>
      <xs:element name="ProjectReference" type="twa:ProjectDependencyType" minOccurs="0" maxOccurs="unbounded"/>
      <xs:element name="PackageReference" type="twa:PackageDependencyType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="path" type="xs:string" use="optional"/>
    <xs:attribute name="targetFramework" type="xs:string" use="optional"/>
    <xs:attribute name="outputType" type="xs:string" use="optional"/>
    <xs:attribute name="sdk" type="xs:string" use="optional"/>
    <xs:attribute name="csFileCount" type="xs:integer" use="optional"/>
    <xs:attribute name="razorFileCount" type="xs:integer" use="optional"/>
    <xs:attribute name="xamlFileCount" type="xs:integer" use="optional"/>
  </xs:complexType>

  <xs:complexType name="ProjectDependencyType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="path" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="PackageDependencyType">
    <xs:attribute name="name" type="xs:string" use="required"/>
    <xs:attribute name="version" type="xs:string" use="optional"/>
  </xs:complexType>

  <xs:complexType name="DependencyGraphType">
    <xs:sequence>
      <xs:element name="Edge" type="twa:DependencyEdgeType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="nodeCount" type="xs:integer" use="optional"/>
    <xs:attribute name="edgeCount" type="xs:integer" use="optional"/>
  </xs:complexType>

