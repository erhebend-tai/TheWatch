rules_version = '2';

// =============================================================================
// TheWatch Firestore Security Rules
// =============================================================================
// Swarm inventory and agent activity collections.
// In production, restrict to authenticated service accounts.
// For development, allow read/write with auth.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Swarm Inventory: file records, supervisors, goals ──────────────
    match /swarm_files/{fileId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /swarm_supervisors/{supervisorId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Agent Activity Logs ───────────────────────────────────────────
    match /agent_activities/{activityId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Feature Tracking (future) ─────────────────────────────────────
    match /features/{featureId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── DevWork Items (future) ────────────────────────────────────────
    match /devwork/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Catch-all: deny by default ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
