{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "TheWatch.DocGen": "Debug",
      "Hangfire": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "TheWatch.DocGen": "Debug",
        "Hangfire": "Information"
      }
    }
  },
  "DocGen": {
    "SolutionRoot": "",
    "WatchEnabled": true,
    "DebounceMs": 500,
    "GenerateOnStartup": true,
    "IncludePrivateMembers": false,
    "IncludeInternalMembers": true,
    "StubMarker": "[AUTO-DOC]",
    "OutputReportPath": "./docs/coverage-report.xml",
    "ExcludedPaths": [ "obj", "bin", "Migrations", ".vs", "node_modules", "TestResults" ],
    "ExcludedFiles": [ "GlobalUsings.cs", "AssemblyInfo.cs" ],
    "MaxConcurrency": 4
  }
}
