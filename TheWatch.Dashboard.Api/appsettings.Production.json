{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error",
      "TheWatch": "Information"
    }
  },
  "ConnectionStrings": {
    "thewatch-sqlserver": "",
    "thewatch-postgresql": "",
    "thewatch-redis": "",
    "thewatch-cosmos": ""
  },
  "AdapterRegistry": {
    "PrimaryStorage": "SqlServer",
    "AuditTrail": "CosmosDb",
    "SpatialIndex": "PostgreSql",
    "GitHub": "Live",
    "Azure": "Live",
    "AWS": "Live",
    "Google": "Live",
    "Oracle": "Disabled",
    "Cloudflare": "Disabled",
    "BlobStorage": "Mock",
    "Evidence": "Mock",
    "Survey": "Mock",
    "FeatureTracking": "Mock",
    "DevWork": "Mock",
    "Embedding": "AzureOpenAI",
    "VectorSearch": "Qdrant"
  },
  "DatabaseSettings": {
    "FirestoreProjectId": "gen-lang-client-0590872284",
    "UseFirestoreEmulator": false,
    "FirestoreEmulatorHost": "",
    "FirestoreCredentialPath": "/etc/thewatch/firestore-credentials.json"
  },
  "AIProviders": {
    "AzureOpenAI": {
      "Endpoint": "https://watch-project-resource.cognitiveservices.azure.com/",
      "ApiKey": "",
      "EmbeddingModel": "text-embedding-3-large",
      "EmbeddingDimensions": 3072,
      "ChatModel": "gpt-4o",
      "SupervisorModel": "gpt-4.1",
      "SpecialistModel": "gpt-4o-mini",
      "ApiVersion": "2024-12-01-preview"
    },
    "Gemini": {
      "ApiKey": "",
      "EmbeddingModel": "text-embedding-004",
      "EmbeddingDimensions": 768,
      "ChatModel": "gemini-2.0-flash"
    },
    "VoyageAI": {
      "ApiKey": "",
      "EmbeddingModel": "voyage-3",
      "EmbeddingDimensions": 1024
    },
    "Claude": {
      "ApiKey": "",
      "Model": "claude-sonnet-4-6"
    },
    "Qdrant": {
      "Endpoint": "http://thewatch-qdrant:6333",
      "GrpcEndpoint": "http://thewatch-qdrant:6334",
      "CollectionName": "thewatch-vectors"
    }
  },
  "Azure": {
    "SignalR": {
      "ConnectionString": ""
    }
  },
  "RabbitMQ": {
    "Host": "rabbitmq.internal.wonderfuldune-4c34e3da.eastus2.azurecontainerapps.io",
    "Port": 5672,
    "VHost": "/",
    "Exchange": "swarm-tasks"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Error",
        "TheWatch": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/thewatch-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  }
}
