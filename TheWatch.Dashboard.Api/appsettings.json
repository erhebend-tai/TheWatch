{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "TheWatch": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "thewatch-sqlserver": "",
    "thewatch-postgresql": "",
    "thewatch-redis": "",
    "thewatch-cosmos": ""
  },
  "DatabaseSettings": {
    "FirestoreProjectId": "thewatch-dev",
    "UseFirestoreEmulator": false,
    "FirestoreEmulatorHost": "localhost:8080",
    "FirestoreCredentialPath": ""
  },
  "AdapterRegistry": {
    "PrimaryStorage": "Mock",
    "AuditTrail": "Mock",
    "SpatialIndex": "Mock",
    "GitHub": "Mock",
    "Azure": "Mock",
    "AWS": "Mock",
    "Google": "Mock",
    "Oracle": "Disabled",
    "Cloudflare": "Disabled",
    "BlobStorage": "Mock",
    "Evidence": "Mock",
    "Survey": "Mock",
    "FeatureTracking": "Mock",
    "DevWork": "Mock",
    "Embedding": "Mock",
    "VectorSearch": "Mock"
  },
  "AIProviders": {
    "AzureOpenAI": {
      "Endpoint": "",
      "ApiKey": "",
      "EmbeddingModel": "text-embedding-3-large",
      "EmbeddingDimensions": 3072,
      "ChatModel": "gpt-4o"
    },
    "Gemini": {
      "ApiKey": "",
      "EmbeddingModel": "text-embedding-004",
      "EmbeddingDimensions": 768,
      "ChatModel": "gemini-2.0-flash"
    },
    "VoyageAI": {
      "ApiKey": "",
      "EmbeddingModel": "voyage-3",
      "EmbeddingDimensions": 1024
    },
    "Claude": {
      "ApiKey": "",
      "Model": "claude-sonnet-4-6"
    },
    "Qdrant": {
      "Endpoint": "http://localhost:6333",
      "GrpcEndpoint": "http://localhost:6334",
      "CollectionName": "thewatch-vectors"
    }
  },
  "Escalation": {
    "InitialDispatchDelaySeconds": 0,
    "WidenScopeDelaySeconds": 300,
    "EmergencyContactsDelaySeconds": 600,
    "FirstRespondersDelaySeconds": 900,
    "MinRespondersBeforeWiden": 2,
    "RadiusMultiplierOnWiden": 2.0,
    "MaxRadiusExpansionMultiplier": 4.0,
    "AutoDial911": true,
    "SweepIntervalSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/thewatch-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  }
}
