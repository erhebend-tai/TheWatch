<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive Icon Definition for TheWatch (Android 8.0+ / API 26+)
    ================================================================
    Uses a vector drawable foreground (shield icon) over a solid color background.
    The adaptive icon system will apply device-specific masks (circle, squircle,
    rounded square, etc.) automatically.

    Foreground: @drawable/ic_launcher_foreground (shield vector)
    Background: @color/ic_launcher_background (brand color)

    Reference: https://developer.android.com/develop/ui/views/launch/icon_design_adaptive

    Example: This file is referenced automatically by the system when
    android:icon="@mipmap/ic_launcher" is set in AndroidManifest.xml.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
