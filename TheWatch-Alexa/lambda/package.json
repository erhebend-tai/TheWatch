  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "ask-sdk-core": "^2.14.0",
    "ask-sdk-model": "^1.39.0",
    "axios": "^1.7.0",
    "axios-retry": "^4.1.0",
    "uuid": "^9.0.0",
    "i18next": "^23.11.0"
  },
  "devDependencies": {
    "mocha": "^10.4.0",
    "chai": "^4.4.0",
    "sinon": "^17.0.0",
    "eslint": "^8.57.0",
    "nock": "^13.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
