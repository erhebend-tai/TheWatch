{
  "name": "thewatch-alexa-skill",
  "version": "1.0.0",
  "description": "TheWatch Safety & Security Alexa Skill - AWS Lambda backend for SOS alerts, check-ins, and safety profile management via voice on Alexa devices.",
  "main": "index.js",
  "scripts": {
    "test": "mocha ../tests/**/*.js --timeout 10000",
    "lint": "eslint .",
    "start": "node index.js",
    "package": "zip -r ../deploy/lambda.zip . -x '*.git*' 'node_modules/.cache/*'"
  },
  "keywords": [
    "alexa",
    "thewatch",
    "safety",
    "security",
    "sos",
    "emergency",
    "iot",
    "voice-assistant"
  ],
