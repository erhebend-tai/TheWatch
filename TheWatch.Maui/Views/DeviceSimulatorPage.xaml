<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TheWatch.Maui.Views.DeviceSimulatorPage"
             Title="Device Simulator"
             BackgroundColor="#FFFFFF">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Device Online Status -->
            <Frame BorderColor="#1B2A4A" CornerRadius="8" Padding="16" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Device Status" FontSize="14" FontAttributes="Bold" TextColor="#1B2A4A" />

                    <HorizontalStackLayout Spacing="12">
                        <VerticalStackLayout HorizontalOptions="FillAndExpand" Spacing="4">
                            <Label
                                Text="{Binding IsDeviceOnline, StringFormat='Status: {0}'}"
                                FontSize="12"
                                FontAttributes="Bold"
                                TextColor="#1B2A4A" />
                            <Label
                                Text="{Binding IsDeviceOnline, StringFormat='Currently {0:Online,Offline}'}"
                                FontSize="11"
                                TextColor="#666666" />
                        </VerticalStackLayout>
                        <Switch IsToggled="{Binding IsDeviceOnline}" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Button
                            Text="Go Online"
                            Command="{Binding SimulateDeviceGoOnlineCommand}"
                            BackgroundColor="#28A745"
                            TextColor="#FFFFFF"
                            FontSize="12"
                            Padding="12,8"
                            CornerRadius="4" />

                        <Button
                            Text="Go Offline"
                            Command="{Binding SimulateDeviceGoOfflineCommand}"
                            BackgroundColor="#DC3545"
                            TextColor="#FFFFFF"
                            FontSize="12"
                            Padding="12,8"
                            CornerRadius="4" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Battery Level -->
            <Frame BorderColor="#1B2A4A" CornerRadius="8" Padding="16" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Battery Level" FontSize="14" FontAttributes="Bold" TextColor="#1B2A4A" />

                    <HorizontalStackLayout Spacing="8">
                        <Slider
                            Value="{Binding BatteryPercentage}"
                            Minimum="0"
                            Maximum="100"
                            HorizontalOptions="FillAndExpand" />
                        <Label
                            Text="{Binding BatteryPercentage, StringFormat='{0:F0}%'}"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#1B2A4A"
                            WidthRequest="50" />
                    </HorizontalStackLayout>

                    <Label
                        Text="{Binding Device.BatteryPercentage, StringFormat='Current: {0}%'}"
                        FontSize="12"
                        TextColor="#666666" />
                </VerticalStackLayout>
            </Frame>

            <!-- Device Type Selection -->
            <Frame BorderColor="#1B2A4A" CornerRadius="8" Padding="16" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Device Type" FontSize="14" FontAttributes="Bold" TextColor="#1B2A4A" />
                    <Picker
                        ItemsSource="{Binding DeviceTypeOptions}"
                        SelectedIndex="{Binding SelectedDeviceTypeIndex}"
                        TextColor="#1B2A4A"
                        BackgroundColor="#F5F5F5"
                        FontSize="14" />
                </VerticalStackLayout>
            </Frame>

            <!-- Location Settings -->
            <Frame BorderColor="#1B2A4A" CornerRadius="8" Padding="16" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Location" FontSize="14" FontAttributes="Bold" TextColor="#1B2A4A" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Latitude" FontSize="12" FontAttributes="Bold" TextColor="#666666" />
                            <Entry
                                Text="{Binding Device.Latitude}"
                                Keyboard="Numeric"
                                PlaceholderColor="#CCCCCC"
                                TextColor="#1B2A4A"
                                BackgroundColor="#F5F5F5"
                                FontSize="12" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Longitude" FontSize="12" FontAttributes="Bold" TextColor="#666666" />
                            <Entry
                                Text="{Binding Device.Longitude}"
                                Keyboard="Numeric"
                                PlaceholderColor="#CCCCCC"
                                TextColor="#1B2A4A"
                                BackgroundColor="#F5F5F5"
                                FontSize="12" />
                        </VerticalStackLayout>
                    </Grid>

                    <Button
                        Text="Get Current Location"
                        Command="{Binding GetCurrentLocationCommand}"
                        BackgroundColor="#28A745"
                        TextColor="#FFFFFF"
                        FontSize="12"
                        Padding="12,8"
                        CornerRadius="4" />
                </VerticalStackLayout>
            </Frame>

            <!-- Security Status -->
            <Frame BorderColor="#1B2A4A" CornerRadius="8" Padding="16" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Security Status" FontSize="14" FontAttributes="Bold" TextColor="#1B2A4A" />

                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="12">
                            <Label Text="Jailbroken" FontSize="12" FontAttributes="Bold" TextColor="#1B2A4A" />
                            <Switch IsToggled="{Binding IsJailbroken}" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="12">
                            <Label Text="Rooted" FontSize="12" FontAttributes="Bold" TextColor="#1B2A4A" />
                            <Switch IsToggled="{Binding IsRooted}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Button
                            Text="Simulate Security Compromise"
                            Command="{Binding SimulateSecurityCompromiseCommand}"
                            BackgroundColor="#DC3545"
                            TextColor="#FFFFFF"
                            FontSize="12"
                            Padding="12,8"
                            CornerRadius="4" />

                        <Button
                            Text="Restore Security"
                            Command="{Binding SimulateSecurityRestoreCommand}"
                            BackgroundColor="#28A745"
                            TextColor="#FFFFFF"
                            FontSize="12"
                            Padding="12,8"
                            CornerRadius="4" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Action Buttons -->
            <VerticalStackLayout Spacing="12">
                <Button
                    Text="Publish Device State"
                    Command="{Binding PublishDeviceStateCommand}"
                    BackgroundColor="#1B2A4A"
                    TextColor="#FFFFFF"
                    FontSize="16"
                    FontAttributes="Bold"
                    Padding="12,12"
                    CornerRadius="4"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />

                <Button
                    Text="Reset"
                    Command="{Binding ResetFormCommand}"
                    BackgroundColor="#6C757D"
                    TextColor="#FFFFFF"
                    FontSize="14"
                    Padding="12,8"
                    CornerRadius="4"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />
            </VerticalStackLayout>

            <!-- Status Message -->
            <Frame
                BorderColor="#E0E0E0"
                CornerRadius="4"
                Padding="12"
                IsVisible="{Binding StatusMessage, Converter={StaticResource StrToBoolConverter}}">
                <Label
                    Text="{Binding StatusMessage}"
                    FontSize="12"
                    TextColor="#1B2A4A"
                    LineBreakMode="WordWrap" />
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
