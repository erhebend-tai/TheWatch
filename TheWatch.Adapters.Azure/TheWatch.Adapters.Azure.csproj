<!--
  TheWatch.Adapters.Azure — Live Azure adapter implementations (Resource Manager, Service Bus,
  Notification Hub). Used in Production with "Azure": "Live" in AdapterRegistry.

  Example — checks Azure resource health:
    IAzurePort azure = serviceProvider.GetRequiredService<IAzurePort>();
    var health = await azure.GetResourceHealthAsync();
-->
<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\TheWatch.Shared\TheWatch.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.ResourceManager" />
    <PackageReference Include="Azure.Messaging.ServiceBus" />
    <PackageReference Include="Azure.ResourceManager.NotificationHubs" />

    <!-- Azure OpenAI — Chat Completions API for swarm agent orchestration -->
    <PackageReference Include="Azure.AI.OpenAI" />
  </ItemGroup>

</Project>
