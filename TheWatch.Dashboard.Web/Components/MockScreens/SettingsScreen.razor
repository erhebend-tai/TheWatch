    </div>

    <div class="settings-content">
        <!-- Notifications Section -->
        <section class="section">
            <h2 class="section-heading">Notifications</h2>

            <div class="form-group toggle-group">
                <label class="form-label">Push Notifications</label>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>

            <div class="form-group toggle-group">
                <label class="form-label">SMS Fallback</label>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>

            <div class="form-group toggle-group">
                <label class="form-label">Email Alerts</label>
                <label class="toggle-switch">
                    <input type="checkbox" />
                    <span class="toggle-slider"></span>
                </label>
            </div>

            <div class="form-group">
                <label class="form-label">Notification Sound</label>
                <select class="form-select">
                    <option>Default Alert</option>
                    <option>Alarm</option>
                    <option>Bell</option>
                    <option>Chime</option>
                    <option>Silent</option>
                </select>
            </div>
        </section>

        <!-- Data & Privacy Section -->
        <section class="section">
            <h2 class="section-heading">Data & Privacy</h2>

            <div class="form-group">
                <label class="form-label">Data Retention</label>
                <div class="form-value">365 days</div>
            </div>

            <div class="button-group">
                <button class="btn-secondary">Export Data</button>
                <button class="btn-danger">Delete All Data</button>
            </div>
        </section>

        <!-- Appearance Section -->
        <section class="section">
            <h2 class="section-heading">Appearance</h2>

            <div class="form-group toggle-group">
                <label class="form-label">Dark Mode</label>
                <label class="toggle-switch">
                    <input type="checkbox" />
                    <span class="toggle-slider"></span>
                </label>
            </div>

            <div class="form-group">
                <label class="form-label">Language</label>
                <select class="form-select">
                    <option>English</option>
                    <option>Spanish</option>
                    <option>French</option>
                    <option>German</option>
                    <option>Mandarin</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Units</label>
                <select class="form-select">
                    <option>Metric (km, kg)</option>
                    <option>Imperial (mi, lbs)</option>
                </select>
            </div>
        </section>

        <!-- About Section -->
        <section class="section">
            <h2 class="section-heading">About</h2>

            <div class="info-row">
                <span class="info-label">App Version</span>
                <span class="info-value">1.4.2</span>
            </div>

            <div class="info-row">
                <span class="info-label">Build Number</span>
                <span class="info-value">2406</span>
            </div>

            <button class="btn-link">View Terms of Service</button>
            <button class="btn-link">View Privacy Policy</button>
        </section>

        <div style="height: 20px;"></div>
    </div>
</div>

