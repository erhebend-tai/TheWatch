
<div class="signup-screen">
    <div class="signup-header">
        <button class="back-btn" title="Go back">‹</button>
        <div class="progress-indicator">
            <span class="progress-label">Step 1 of 3</span>
            <div class="progress-dots">
                <span class="dot active"></span>
                <span class="dot"></span>
                <span class="dot"></span>
            </div>
        </div>
    </div>

    <div class="signup-content">
        <h1 class="signup-title">Create Your Account</h1>
        <p class="signup-subtitle">Tell us who you are</p>

        <form class="signup-form">
            <div class="form-group">
                <label for="full-name">Full Name</label>
                <input
                    id="full-name"
                    type="text"
                    placeholder="First and last name"
                    class="form-input"
                    value="Alex Rivera"
                />
            </div>

            <div class="form-group">
                <label for="email">Email</label>
                <input
                    id="email"
                    type="email"
                    placeholder="your@email.com"
                    class="form-input"
                    value="alex.rivera@example.com"
                />
            </div>

            <div class="form-group">
                <label for="phone">Phone Number</label>
                <div class="phone-input-group">
                    <select class="country-code">
                        <option>+1</option>
                        <option>+44</option>
                        <option>+33</option>
                    </select>
                    <input
                        id="phone"
                        type="tel"
                        placeholder="(555) 123-4567"
                        class="form-input phone-number-input"
                        value="(555) 123-4567"
                    />
                </div>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input
                    id="password"
                    type="password"
                    placeholder="Create a strong password"
                    class="form-input"
                />
                <div class="strength-meter">
                    <div class="strength-bar strong"></div>
                    <span class="strength-text">Strong</span>
                </div>
            </div>

            <div class="form-group">
                <label for="confirm-password">Confirm Password</label>
                <input
                    id="confirm-password"
                    type="password"
                    placeholder="Confirm your password"
                    class="form-input"
                />
            </div>

            <div class="form-group">
                <label for="dob">Date of Birth</label>
                <div class="date-input-wrapper">
                    <input
                        id="dob"
                        type="date"
                        class="form-input date-input"
                        value="1992-07-15"
                    />
                    <span class="calendar-icon">📅</span>
                </div>
            </div>
        </form>
    </div>

    <div class="signup-footer">
        <div class="form-links">
            <a href="#" class="form-link">Back to Login</a>
        </div>
        <button class="btn-next">Next</button>
    </div>
</div>

