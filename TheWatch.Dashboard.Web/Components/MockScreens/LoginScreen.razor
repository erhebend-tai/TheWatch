
<div class="login-screen">
    <div class="offline-banner">
        <span class="wifi-icon">◐</span>
        <span>Offline — Limited functionality</span>
    </div>

    <div class="gradient-background"></div>

    <div class="login-content">
        <div class="logo-container">
            <div class="logo-circle">
                <span class="logo-letter">W</span>
            </div>
        </div>

        <div class="wordmark">TheWatch</div>

        <form class="login-form">
            <div class="form-group">
                <label for="email-input">Email or Phone Number</label>
                <input
                    id="email-input"
                    type="text"
                    placeholder="Email or phone number"
                    class="form-input"
                />
            </div>

            <div class="form-group">
                <label for="password-input">Password</label>
                <div class="password-field">
                    <input
                        id="password-input"
                        type="password"
                        placeholder="Password"
                        class="form-input password-input"
                    />
                    <button type="button" class="show-toggle" title="Show/hide password">
                        <span class="eye-icon">◉</span>
                    </button>
                </div>
            </div>

            <div class="form-links">
                <a href="#" class="form-link">Forgot Password?</a>
                <a href="#" class="form-link">Sign Up</a>
            </div>

            <button type="submit" class="btn-primary btn-sign-in">Sign In</button>

            <button type="button" class="btn-biometric">
                <span class="fingerprint-icon">⊕</span>
                <span>Fingerprint Sign In</span>
            </button>
        </form>

        <div class="sos-link">
            <a href="#" class="emergency-link">Emergency SOS — No sign-in required</a>
        </div>
    </div>
</div>

