@page "/responders"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject DashboardApiClient ApiClient
@inject DashboardHubService HubService
@inject ISnackbar Snackbar
@implements IAsyncDisposable

@* =============================================================================
   Responders.razor — Registered responder management table.
   =============================================================================
   Lists all registered volunteer responders with their status, location,
   capabilities (certifications), vehicle availability, and current availability.

   Filters: availability toggle, role/certification, distance from a reference point.

   API endpoints used:
     GET /api/response/participation/{userId} — individual participation prefs
     PUT /api/response/participation          — update preferences

   The full responder roster would come from a dedicated admin endpoint:
     GET /api/responders?available=true&scope=Neighborhood&lat=30.27&lng=-97.74&radius=5000

   WAL: Table supports MudTable filtering/sorting. Responder location updates
        arrive via SignalR and update the distance column in real-time.
   ============================================================================= *@

<PageTitle>Responders — TheWatch</PageTitle>

<div class="page-header px-6 pt-6 pb-3">
    <div class="d-flex justify-space-between align-center">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold">Responder Management</MudText>
            <MudText Typo="Typo.body2" Style="opacity: 0.6;">
                Registered volunteers, certified responders, and trusted contacts.
            </MudText>
        </div>
        <MudChip T="string" Color="@(HubService.IsConnected ? Color.Success : Color.Error)"
                 Size="Size.Small" Variant="Variant.Filled">
            @(HubService.IsConnected ? "LIVE" : "OFFLINE")
        </MudChip>
    </div>
</div>

@* ── Summary Cards ───────────────────────────────────────────── *@
<MudGrid Class="px-6 mb-4">
    <MudItem xs="6" sm="3">
        <MudCard Elevation="1" Style="border-radius: 12px;">
            <MudCardContent Class="pa-3 text-center">
                <MudText Typo="Typo.h4" Color="Color.Primary" Class="font-weight-bold">@_responders.Count</MudText>
                <MudText Typo="Typo.caption" Style="opacity: 0.6;">Total Registered</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="1" Style="border-radius: 12px;">
            <MudCardContent Class="pa-3 text-center">
                <MudText Typo="Typo.h4" Color="Color.Success" Class="font-weight-bold">
                    @_responders.Count(r => r.IsCurrentlyAvailable)
                </MudText>
                <MudText Typo="Typo.caption" Style="opacity: 0.6;">Available Now</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="1" Style="border-radius: 12px;">
            <MudCardContent Class="pa-3 text-center">
                <MudText Typo="Typo.h4" Color="Color.Warning" Class="font-weight-bold">
                    @_responders.Count(r => r.Certifications?.Length > 0)
                </MudText>
                <MudText Typo="Typo.caption" Style="opacity: 0.6;">Certified</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="1" Style="border-radius: 12px;">
            <MudCardContent Class="pa-3 text-center">
                <MudText Typo="Typo.h4" Color="Color.Info" Class="font-weight-bold">
                    @_responders.Count(r => r.HasVehicle)
                </MudText>
                <MudText Typo="Typo.caption" Style="opacity: 0.6;">With Vehicle</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@* ── Filters ─────────────────────────────────────────────────── *@
<MudGrid Class="px-6 mb-4">
    <MudItem xs="12" sm="3">
        <MudSelect T="string" Label="Availability" Value="@_availabilityFilter"
                   ValueChanged="OnAvailabilityFilterChanged"
                   Variant="Variant.Outlined" Clearable="true">
            <MudSelectItem T="string" Value="@("All")">All</MudSelectItem>
            <MudSelectItem T="string" Value="@("Available")">Available Now</MudSelectItem>
            <MudSelectItem T="string" Value="@("Unavailable")">Unavailable</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudSelect T="string" Label="Certification" Value="@_certFilter"
                   ValueChanged="OnCertFilterChanged"
                   Variant="Variant.Outlined" Clearable="true">
            <MudSelectItem T="string" Value="@("All")">All Roles</MudSelectItem>
            <MudSelectItem T="string" Value="@("EMT")">EMT</MudSelectItem>
            <MudSelectItem T="string" Value="@("NURSE")">Nurse</MudSelectItem>
            <MudSelectItem T="string" Value="@("CPR")">CPR Certified</MudSelectItem>
            <MudSelectItem T="string" Value="@("FIRST_AID")">First Aid</MudSelectItem>
            <MudSelectItem T="string" Value="@("VOLUNTEER")">Volunteer (no cert)</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudSelect T="string" Label="Scope Opt-In" Value="@_scopeFilter"
                   ValueChanged="OnScopeFilterChanged"
                   Variant="Variant.Outlined" Clearable="true">
            <MudSelectItem T="string" Value="@("All")">All Scopes</MudSelectItem>
            <MudSelectItem T="string" Value="@("CheckIn")">Check-In</MudSelectItem>
            <MudSelectItem T="string" Value="@("Neighborhood")">Neighborhood</MudSelectItem>
            <MudSelectItem T="string" Value="@("Community")">Community</MudSelectItem>
            <MudSelectItem T="string" Value="@("Evacuation")">Evacuation</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudTextField T="string" Label="Search" @bind-Value="_searchQuery"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="300"
                      Placeholder="Name, user ID..." />
    </MudItem>
</MudGrid>

@* ── Responders Table ────────────────────────────────────────── *@
<MudPaper Class="mx-6 mb-6" Elevation="2" Style="border-radius: 12px; overflow: hidden;">
    <MudTable T="ResponderRow" Items="@FilteredResponders" Hover="true" Dense="true"
              Breakpoint="Breakpoint.Sm" Loading="@_loading"
              SortLabel="Sort" AllowUnsorted="false"
              FixedHeader="true" Height="calc(100vh - 420px)">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="ResponderRow" SortBy="@(x => x.Prefs.UserId)">User</MudTableSortLabel></MudTh>
            <MudTh>Availability</MudTh>
            <MudTh>Certifications</MudTh>
            <MudTh>Vehicle</MudTh>
            <MudTh>Scope Opt-In</MudTh>
            <MudTh><MudTableSortLabel T="ResponderRow" SortBy="@(x => x.Prefs.MaxResponseRadiusMeters)">Max Radius</MudTableSortLabel></MudTh>
            <MudTh>Quiet Hours</MudTh>
            <MudTh><MudTableSortLabel T="ResponderRow" SortBy="@(x => x.Prefs.LastUpdated)">Last Updated</MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="User">
                <div class="d-flex align-center gap-2">
                    <MudAvatar Size="Size.Small"
                               Color="@(context.Prefs.IsCurrentlyAvailable ? Color.Success : Color.Default)">
                        @context.Prefs.UserId[..1].ToUpper()
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.body2">@context.DisplayName</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.5; font-family: monospace;">
                            @context.Prefs.UserId[..Math.Min(12, context.Prefs.UserId.Length)]
                        </MudText>
                    </div>
                </div>
            </MudTd>
            <MudTd DataLabel="Availability">
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Prefs.IsCurrentlyAvailable ? Color.Success : Color.Default)"
                         Variant="@(context.Prefs.IsCurrentlyAvailable ? Variant.Filled : Variant.Outlined)">
                    @(context.Prefs.IsCurrentlyAvailable ? "Available" : "Unavailable")
                </MudChip>
                @if (context.Prefs.AvailableFrom.HasValue && context.Prefs.AvailableTo.HasValue)
                {
                    <MudText Typo="Typo.caption" Style="opacity: 0.5;">
                        @context.Prefs.AvailableFrom.Value.ToString("HH:mm")–@context.Prefs.AvailableTo.Value.ToString("HH:mm")
                    </MudText>
                }
            </MudTd>
            <MudTd DataLabel="Certifications">
                @if (context.Prefs.Certifications?.Length > 0)
                {
                    @foreach (var cert in context.Prefs.Certifications)
                    {
                        <MudChip T="string" Size="Size.Small" Color="@GetCertColor(cert)"
                                 Variant="Variant.Text" Class="mr-1">
                            @cert
                        </MudChip>
                    }
                }
                else
                {
                    <MudText Typo="Typo.caption" Style="opacity: 0.4;">None</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Vehicle">
                <MudIcon Icon="@(context.Prefs.HasVehicle ? Icons.Material.Filled.DirectionsCar : Icons.Material.Filled.DirectionsWalk)"
                         Size="Size.Small"
                         Color="@(context.Prefs.HasVehicle ? Color.Success : Color.Default)" />
            </MudTd>
            <MudTd DataLabel="Scope Opt-In">
                <div class="d-flex gap-1 flex-wrap">
                    @if (context.Prefs.OptedInCheckIn) { <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">Check-In</MudChip> }
                    @if (context.Prefs.OptedInNeighborhood) { <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">Neighborhood</MudChip> }
                    @if (context.Prefs.OptedInCommunity) { <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text">Community</MudChip> }
                    @if (context.Prefs.OptedInEvacuation) { <MudChip T="string" Size="Size.Small" Color="Color.Dark" Variant="Variant.Text">Evacuation</MudChip> }
                </div>
            </MudTd>
            <MudTd DataLabel="Max Radius">
                <MudText Typo="Typo.caption">
                    @FormatDistance(context.Prefs.MaxResponseRadiusMeters)
                </MudText>
            </MudTd>
            <MudTd DataLabel="Quiet Hours">
                @if (context.Prefs.QuietHoursStart.HasValue && context.Prefs.QuietHoursEnd.HasValue)
                {
                    <MudText Typo="Typo.caption">
                        @context.Prefs.QuietHoursStart.Value.ToString("HH:mm")–@context.Prefs.QuietHoursEnd.Value.ToString("HH:mm")
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Style="opacity: 0.4;">None</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Last Updated">
                <MudText Typo="Typo.caption" Style="font-family: monospace;">
                    @context.Prefs.LastUpdated.ToString("MM/dd HH:mm")
                </MudText>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Align="Align.Center" Typo="Typo.body1" Class="pa-8" Style="opacity: 0.5;">
                No responders match the current filters.
            </MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText Align="Align.Center" Class="pa-8">Loading responders...</MudText>
        </LoadingContent>
    </MudTable>
</MudPaper>

@code {
    // ── State ────────────────────────────────────────────────────
    private List<ResponderRow> _responders = new();
    private bool _loading = true;
    private string _availabilityFilter = "All";
    private string _certFilter = "All";
    private string _scopeFilter = "All";
    private string _searchQuery = "";

    private IEnumerable<ResponderRow> FilteredResponders => _responders
        .Where(r => _availabilityFilter == "All" ||
                     (_availabilityFilter == "Available" && r.Prefs.IsCurrentlyAvailable) ||
                     (_availabilityFilter == "Unavailable" && !r.Prefs.IsCurrentlyAvailable))
        .Where(r => _certFilter == "All" ||
                     (_certFilter == "VOLUNTEER" && (r.Prefs.Certifications is null || r.Prefs.Certifications.Length == 0)) ||
                     (r.Prefs.Certifications?.Contains(_certFilter) ?? false))
        .Where(r => _scopeFilter == "All" ||
                     (_scopeFilter == "CheckIn" && r.Prefs.OptedInCheckIn) ||
                     (_scopeFilter == "Neighborhood" && r.Prefs.OptedInNeighborhood) ||
                     (_scopeFilter == "Community" && r.Prefs.OptedInCommunity) ||
                     (_scopeFilter == "Evacuation" && r.Prefs.OptedInEvacuation))
        .Where(r => string.IsNullOrEmpty(_searchQuery) ||
                     r.Prefs.UserId.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                     r.DisplayName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    // ── Lifecycle ────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        HubService.OnConnectionChanged += HandleConnectionChanged;
        await HubService.StartAsync();
        await LoadRespondersAsync();
    }

    private async Task LoadRespondersAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            // In production, a dedicated admin endpoint would return the full
            // responder roster. Example:
            //   GET /api/responders?page=1&pageSize=100
            // For now, the table structure is ready to receive ParticipationPreferences
            // data from the API when the endpoint is implemented.
            //
            // var prefs = await ApiClient.GetAllRespondersAsync();
            // _responders = prefs.Select(p => new ResponderRow(p)).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load responders: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async void HandleConnectionChanged(HubConnectionState state)
    {
        await InvokeAsync(StateHasChanged);
    }

    // ── Filter Handlers ──────────────────────────────────────────
    private void OnAvailabilityFilterChanged(string value)
    {
        _availabilityFilter = value ?? "All";
    }

    private void OnCertFilterChanged(string value)
    {
        _certFilter = value ?? "All";
    }

    private void OnScopeFilterChanged(string value)
    {
        _scopeFilter = value ?? "All";
    }

    // ── Helper Methods ───────────────────────────────────────────
    private static string FormatDistance(double meters)
    {
        if (meters >= 1000) return $"{meters / 1000:F1} km";
        return $"{meters:F0} m";
    }

    private static Color GetCertColor(string cert) => cert switch
    {
        "EMT" => Color.Error,
        "NURSE" => Color.Primary,
        "CPR" => Color.Warning,
        "FIRST_AID" => Color.Info,
        _ => Color.Default
    };

    // ── Disposal ─────────────────────────────────────────────────
    public ValueTask DisposeAsync()
    {
        HubService.OnConnectionChanged -= HandleConnectionChanged;
        return ValueTask.CompletedTask;
    }

    // ── Row Model ────────────────────────────────────────────────
    public class ResponderRow
    {
        public ParticipationPreferences Prefs { get; set; } = default!;
        public string DisplayName { get; set; } = "Unknown";
        public bool IsCurrentlyAvailable => Prefs.IsCurrentlyAvailable;
        public string[]? Certifications => Prefs.Certifications;
        public bool HasVehicle => Prefs.HasVehicle;

        public ResponderRow() { }
        public ResponderRow(ParticipationPreferences prefs, string? displayName = null)
        {
            Prefs = prefs;
            DisplayName = displayName ?? prefs.UserId;
        }
    }
}

<style>
    .page-header {
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
</style>
