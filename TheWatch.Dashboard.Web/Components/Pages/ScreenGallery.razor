<style>
    .screen-gallery-container {
        display: flex;
        height: 100vh;
        background: #f5f5f5;
        margin-left: 0;
    }

    .gallery-sidebar {
        width: 220px;
        background: white;
        border-right: 1px solid #e0e0e0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .sidebar-header {
        padding: 20px 16px;
        border-bottom: 1px solid #e0e0e0;
    }

    .sidebar-header h2 {
        margin: 0;
        font-size: 18px;
        color: #1b2a4a;
        font-weight: 700;
    }

    .screen-count {
        display: block;
        font-size: 12px;
        color: #888;
        margin-top: 4px;
    }

    .screens-list {
        flex: 1;
        overflow-y: auto;
        padding: 8px 0;
    }

    .screen-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        cursor: pointer;
        transition: all 0.15s;
        border-left: 3px solid transparent;
    }

    .screen-item:hover {
        background: #f9f9f9;
    }

    .screen-item.active {
        background: #e8f4ff;
        border-left-color: #dc3545;
    }

    .screen-indicator {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .screen-indicator.implemented {
        background: #28a745;
        box-shadow: 0 0 4px #28a745;
    }

    .screen-indicator.partial {
        background: #ffc107;
    }

    .screen-indicator.planned {
        background: #ccc;
    }

    .screen-name {
        font-size: 13px;
        color: #333;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .screen-item.active .screen-name {
        color: #dc3545;
        font-weight: 600;
    }

    .gallery-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .preview-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 24px;
        background: white;
        border-bottom: 1px solid #e0e0e0;
    }

    .preview-header h3 {
        margin: 0;
        font-size: 20px;
        color: #1b2a4a;
        font-weight: 700;
    }

    .device-toggle {
        display: flex;
        gap: 16px;
    }

    .device-toggle label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #333;
        cursor: pointer;
    }

    .device-toggle input[type="radio"] {
        width: 16px;
        height: 16px;
        cursor: pointer;
    }

    .preview-container {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 24px;
        overflow: auto;
    }

    .props-inspector {
        background: white;
        border-top: 1px solid #e0e0e0;
        max-height: 200px;
        overflow-y: auto;
    }

    .inspector-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 24px;
        border-bottom: 1px solid #e0e0e0;
    }

    .inspector-header h4 {
        margin: 0;
        font-size: 14px;
        color: #1b2a4a;
        font-weight: 700;
    }

    .inspector-badge {
        font-size: 11px;
        background: #e8f4ff;
        color: #1b2a4a;
        padding: 4px 8px;
        border-radius: 4px;
        font-weight: 600;
    }

    .props-list {
        padding: 0;
    }

    .prop-item {
        display: flex;
        gap: 12px;
        padding: 8px 24px;
        font-size: 12px;
        border-bottom: 1px solid #f0f0f0;
    }

    .prop-item.empty {
        justify-content: center;
        color: #999;
        font-style: italic;
    }

    .prop-key {
        color: #1b2a4a;
        font-weight: 600;
        min-width: 120px;
    }

    .prop-value {
        color: #666;
        font-family: 'Courier New', monospace;
        word-break: break-all;
    }

    /* Scrollbar styling */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

