    private string GetSelectedScreenName()
    {
        var screen = screens.FirstOrDefault(s => s.Id == selectedScreen);
        return screen?.Name ?? "Unknown";
    }

    private RenderFragment GetScreenRender()
    {
        return selectedScreen switch
        {
            "login" => @<LoginScreen />,
            "signup" => @<SignUpScreen />,
            "forgot-password" => @<ForgotPasswordScreen />,
            "reset-password" => @<ResetPasswordScreen />,
            "eula" => @<EULAScreen />,
            "home-map" => @<HomeMapScreen />,
            "nav-drawer" => @<NavigationDrawer />,
            "profile" => @<ProfileScreen />,
            "permissions" => @<PermissionsScreen />,
            "history" => @<HistoryScreen />,
            "volunteering" => @<VolunteeringScreen />,
            "contacts" => @<ContactsScreen />,
            "settings" => @<SettingsScreen />,
            "evacuation" => @<EvacuationScreen />,
            _ => @<div>Unknown screen</div>,
