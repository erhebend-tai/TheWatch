@page "/screens"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager

<div class="screen-gallery-container">
    <div class="gallery-sidebar">
        <div class="sidebar-header">
            <h2>App Screens</h2>
            <span class="screen-count">@screens.Length screens</span>
        </div>

        <div class="screens-list">
            @foreach (var screen in screens)
            {
                var isSelected = selectedScreen == screen.Id;
                <div class="screen-item @(isSelected ? "active" : "")"
                     @onclick="() => SelectScreen(screen.Id)">
                    <span class="screen-indicator @screen.Status"></span>
                    <span class="screen-name">@screen.Name</span>
                </div>
            }
        </div>
    </div>

    <div class="gallery-main">
        <div class="preview-header">
            <h3>@GetSelectedScreenName()</h3>

            <div class="device-toggle">
                <label>
                    <input type="radio" name="device" value="iphone"
                           @onchange='() => SetDeviceType("iphone")'
                           checked="@(deviceType == "iphone")" />
                    iPhone
                </label>
                <label>
                    <input type="radio" name="device" value="android"
                           @onchange='() => SetDeviceType("android")'
                           checked="@(deviceType == "android")" />
                    Android
                </label>
            </div>
        </div>

        <div class="preview-container">
            <PhoneFrame DeviceType="@deviceType">
                @GetScreenRender()
            </PhoneFrame>
        </div>

        <div class="props-inspector">
            <div class="inspector-header">
                <h4>Props Inspector</h4>
                <span class="inspector-badge">@GetSelectedScreenName()</span>
            </div>

            <div class="props-list">
                @if (screenProps.TryGetValue(selectedScreen, out var props))
                {
                    @foreach (var prop in props)
                    {
                        <div class="prop-item">
                            <span class="prop-key">@prop.Key:</span>
                            <span class="prop-value">@prop.Value</span>
                        </div>
                    }
                }
                else
                {
                    <div class="prop-item empty">No props available</div>
                }
            </div>
        </div>
    </div>
</div>

