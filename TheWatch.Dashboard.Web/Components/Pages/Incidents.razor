@page "/incidents"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject DashboardApiClient ApiClient
@inject DashboardHubService HubService
@inject ISnackbar Snackbar
@implements IAsyncDisposable

@* =============================================================================
   Incidents.razor — Full incident management table with detail expansion.
   =============================================================================
   Lists all incidents (active + resolved) with filtering, sorting, and a
   click-to-expand detail panel showing full timeline, responders, and evidence.

   API endpoints used:
     GET /api/response/{requestId}         — full situation snapshot
     GET /api/response/active/{userId}     — active requests
     GET /api/response/{requestId}/messages — message history

   SignalR events consumed:
     ResponderLocationUpdated, ResponderOnScene, EvidenceSubmitted

   WAL: Table uses MudTable server-side pagination pattern. Expansion panels
        lazy-load the full situation from the API on first open.
   ============================================================================= *@

<PageTitle>Incidents — TheWatch</PageTitle>

<div class="page-header px-6 pt-6 pb-3">
    <MudText Typo="Typo.h4" Class="font-weight-bold">Incident Management</MudText>
    <MudText Typo="Typo.body2" Style="opacity: 0.6;">
        All incidents — active, resolved, and cancelled. Click any row to expand details.
    </MudText>
</div>

@* ── Filters ─────────────────────────────────────────────────── *@
<MudGrid Class="px-6 mb-4">
    <MudItem xs="12" sm="4" md="3">
        <MudSelect T="string" Label="Status" Value="@_statusFilter" ValueChanged="OnStatusFilterChanged"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
            <MudSelectItem T="string" Value="@("All")">All Statuses</MudSelectItem>
            @foreach (var status in Enum.GetValues<ResponseStatus>())
            {
                <MudSelectItem T="string" Value="@status.ToString()">@status</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="4" md="3">
        <MudSelect T="string" Label="Scope" Value="@_scopeFilter" ValueChanged="OnScopeFilterChanged"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
            <MudSelectItem T="string" Value="@("All")">All Scopes</MudSelectItem>
            @foreach (var scope in Enum.GetValues<ResponseScope>())
            {
                <MudSelectItem T="string" Value="@scope.ToString()">@scope</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="4" md="3">
        <MudTextField T="string" Label="Search" @bind-Value="_searchQuery"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="300"
                      Placeholder="Request ID, description..." />
    </MudItem>
    <MudItem xs="12" sm="12" md="3" Class="d-flex align-center">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RefreshDataAsync"
                   StartIcon="@Icons.Material.Filled.Refresh" FullWidth="true">
            Refresh
        </MudButton>
    </MudItem>
</MudGrid>

@* ── Incidents Table ─────────────────────────────────────────── *@
<MudPaper Class="mx-6 mb-6" Elevation="2" Style="border-radius: 12px; overflow: hidden;">
    <MudTable T="IncidentRow" Items="@FilteredIncidents" Hover="true" Dense="true"
              Breakpoint="Breakpoint.Sm" Loading="@_loading"
              SortLabel="Sort" AllowUnsorted="false"
              OnRowClick="@(args => ToggleDetail(args.Item))"
              RowStyleFunc="@((item, _) => item.IsExpanded ? "background: rgba(92,138,255,0.05);" : "")"
              FixedHeader="true" Height="calc(100vh - 320px)">
        <HeaderContent>
            <MudTh><MudTableSortLabel T="IncidentRow" SortBy="@(x => x.Request.CreatedAt)">Time</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="IncidentRow" SortBy="@(x => x.Request.RequestId)">Request ID</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="IncidentRow" SortBy="@(x => x.Request.Scope)">Scope</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="IncidentRow" SortBy="@(x => x.Request.Status)">Status</MudTableSortLabel></MudTh>
            <MudTh>Trigger</MudTh>
            <MudTh><MudTableSortLabel T="IncidentRow" SortBy="@(x => x.AckCount)">Responders</MudTableSortLabel></MudTh>
            <MudTh>Elapsed</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Time">
                <MudText Typo="Typo.caption" Style="font-family: monospace;">
                    @context.Request.CreatedAt.ToString("MM/dd HH:mm:ss")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Request ID">
                <MudText Typo="Typo.body2" Style="font-family: monospace;">
                    @context.Request.RequestId[..Math.Min(12, context.Request.RequestId.Length)]
                </MudText>
            </MudTd>
            <MudTd DataLabel="Scope">
                <MudChip T="string" Size="Size.Small" Color="@GetScopeColor(context.Request.Scope)"
                         Variant="Variant.Filled">
                    @context.Request.Scope
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Request.Status)"
                         Variant="Variant.Outlined">
                    @context.Request.Status
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Trigger">
                <MudText Typo="Typo.caption">@(context.Request.TriggerSource ?? "—")</MudText>
            </MudTd>
            <MudTd DataLabel="Responders">
                <MudText Typo="Typo.body2">
                    @context.AckCount / @context.Request.DesiredResponderCount
                </MudText>
            </MudTd>
            <MudTd DataLabel="Elapsed">
                <MudText Typo="Typo.caption" Style="font-family: monospace;">
                    @FormatElapsed(DateTime.UtcNow - context.Request.CreatedAt)
                </MudText>
            </MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (context.IsExpanded)
            {
                <MudTr>
                    <td colspan="7">
                        <MudCard Class="ma-2" Elevation="0" Style="background: rgba(255,255,255,0.02);">
                            <MudCardContent>
                                @if (context.LoadingSituation)
                                {
                                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                                }
                                else if (context.Situation is not null)
                                {
                                    <MudGrid>
                                        @* ── Incident Details ──── *@
                                        <MudItem xs="12" md="4">
                                            <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Primary">
                                                Incident Details
                                            </MudText>
                                            <MudSimpleTable Dense="true" Bordered="true">
                                                <tbody>
                                                    <tr><td><strong>Request ID</strong></td><td style="font-family: monospace;">@context.Request.RequestId</td></tr>
                                                    <tr><td><strong>User ID</strong></td><td>@context.Request.UserId</td></tr>
                                                    <tr><td><strong>Scope</strong></td><td>@context.Request.Scope</td></tr>
                                                    <tr><td><strong>Escalation Policy</strong></td><td>@context.Request.Escalation</td></tr>
                                                    <tr><td><strong>Strategy</strong></td><td>@context.Request.Strategy</td></tr>
                                                    <tr><td><strong>Radius</strong></td><td>@(context.Request.RadiusMeters)m</td></tr>
                                                    <tr><td><strong>Location</strong></td><td>@context.Request.Latitude.ToString("F5"), @context.Request.Longitude.ToString("F5")</td></tr>
                                                    <tr><td><strong>Created</strong></td><td>@context.Request.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</td></tr>
                                                    @if (context.Request.Description is not null)
                                                    {
                                                        <tr><td><strong>Description</strong></td><td>@context.Request.Description</td></tr>
                                                    }
                                                </tbody>
                                            </MudSimpleTable>
                                        </MudItem>

                                        @* ── Responder List ──── *@
                                        <MudItem xs="12" md="4">
                                            <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Primary">
                                                Responders (@context.Situation.TotalAcknowledged ack / @context.Situation.TotalOnScene on scene)
                                            </MudText>
                                            @if (context.Situation.Acknowledgments.Any())
                                            {
                                                @foreach (var ack in context.Situation.Acknowledgments)
                                                {
                                                    <div class="d-flex align-center gap-2 mb-2">
                                                        <MudAvatar Size="Size.Small"
                                                                   Color="@GetAckStatusColor(ack.Status)">
                                                            @ack.ResponderName[..1].ToUpper()
                                                        </MudAvatar>
                                                        <div>
                                                            <MudText Typo="Typo.body2">@ack.ResponderName</MudText>
                                                            <MudText Typo="Typo.caption" Style="opacity: 0.6;">
                                                                @ack.Status — @FormatDistance(ack.DistanceMeters)
                                                                @if (ack.EstimatedArrival.HasValue)
                                                                {
                                                                    <text> — ETA @ack.EstimatedArrival.Value.TotalMinutes.ToString("F0") min</text>
                                                                }
                                                            </MudText>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Style="opacity: 0.5;">No responders yet.</MudText>
                                            }
                                        </MudItem>

                                        @* ── Escalation History ──── *@
                                        <MudItem xs="12" md="4">
                                            <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Primary">
                                                Escalation History
                                            </MudText>
                                            @if (context.Situation.EscalationHistory.Any())
                                            {
                                                <MudTimeline TimelineOrientation="TimelineOrientation.Vertical"
                                                             TimelinePosition="TimelinePosition.Start">
                                                    @foreach (var esc in context.Situation.EscalationHistory.OrderBy(e => e.TriggeredAt))
                                                    {
                                                        <MudTimelineItem Color="@GetEscalationColor(esc.PolicyTriggered)"
                                                                         Size="Size.Small">
                                                            <ItemContent>
                                                                <MudText Typo="Typo.caption">
                                                                    <strong>@esc.PolicyTriggered</strong> — @esc.Reason
                                                                </MudText>
                                                                <MudText Typo="Typo.caption" Style="opacity: 0.5;">
                                                                    @esc.TriggeredAt.ToString("HH:mm:ss")
                                                                </MudText>
                                                            </ItemContent>
                                                        </MudTimelineItem>
                                                    }
                                                </MudTimeline>
                                            }
                                            else
                                            {
                                                <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Text">
                                                    No escalations triggered.
                                                </MudAlert>
                                            }
                                        </MudItem>
                                    </MudGrid>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true">
                                        Could not load incident details.
                                    </MudAlert>
                                }
                            </MudCardContent>
                        </MudCard>
                    </td>
                </MudTr>
            }
        </ChildRowContent>
        <NoRecordsContent>
            <MudText Align="Align.Center" Typo="Typo.body1" Class="pa-8" Style="opacity: 0.5;">
                No incidents match the current filters.
            </MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText Align="Align.Center" Class="pa-8">Loading incidents...</MudText>
        </LoadingContent>
    </MudTable>
</MudPaper>

@code {
    // ── State ────────────────────────────────────────────────────
    private List<IncidentRow> _incidents = new();
    private bool _loading = true;
    private string _statusFilter = "All";
    private string _scopeFilter = "All";
    private string _searchQuery = "";

    private IEnumerable<IncidentRow> FilteredIncidents => _incidents
        .Where(i => _statusFilter == "All" || i.Request.Status.ToString() == _statusFilter)
        .Where(i => _scopeFilter == "All" || i.Request.Scope.ToString() == _scopeFilter)
        .Where(i => string.IsNullOrEmpty(_searchQuery) ||
                     i.Request.RequestId.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                     (i.Request.Description?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderByDescending(i => i.Request.CreatedAt);

    // ── Lifecycle ────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        HubService.OnConnectionChanged += HandleConnectionChanged;
        await HubService.StartAsync();
        await RefreshDataAsync();
    }

    private async Task RefreshDataAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            // In a full implementation, there would be an admin endpoint like
            // GET /api/response/all that returns all incidents with pagination.
            // For now, we populate with sample data structure to demonstrate the UI.
            // The API integration would be:
            //   var incidents = await ApiClient.GetAllIncidentsAsync(page, pageSize, statusFilter, scopeFilter);
            //   _incidents = incidents.Select(i => new IncidentRow(i)).ToList();

            // Placeholder: the table is ready to receive real ResponseRequest data
            // from the API when the endpoint is available.
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load incidents: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async void HandleConnectionChanged(HubConnectionState state)
    {
        await InvokeAsync(StateHasChanged);
    }

    // ── Row Expansion ────────────────────────────────────────────
    private async Task ToggleDetail(IncidentRow row)
    {
        row.IsExpanded = !row.IsExpanded;

        if (row.IsExpanded && row.Situation is null && !row.LoadingSituation)
        {
            row.LoadingSituation = true;
            StateHasChanged();

            try
            {
                // Load full situation from API
                // var situation = await ApiClient.GetSituationAsync(row.Request.RequestId);
                // row.Situation = situation;

                // Join the response group for real-time updates
                await HubService.JoinResponseGroupAsync(row.Request.RequestId);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to load details: {ex.Message}", Severity.Warning);
            }
            finally
            {
                row.LoadingSituation = false;
            }
        }

        StateHasChanged();
    }

    // ── Filter Handlers ──────────────────────────────────────────
    private void OnStatusFilterChanged(string value)
    {
        _statusFilter = value ?? "All";
        StateHasChanged();
    }

    private void OnScopeFilterChanged(string value)
    {
        _scopeFilter = value ?? "All";
        StateHasChanged();
    }

    // ── Helper Methods ───────────────────────────────────────────
    private static string FormatElapsed(TimeSpan elapsed)
    {
        if (elapsed.TotalDays >= 1)
            return $"{elapsed.Days}d {elapsed.Hours}h";
        if (elapsed.TotalHours >= 1)
            return $"{elapsed.Hours}h {elapsed.Minutes}m";
        if (elapsed.TotalMinutes >= 1)
            return $"{elapsed.Minutes}m {elapsed.Seconds}s";
        return $"{elapsed.Seconds}s";
    }

    private static string FormatDistance(double meters)
    {
        if (meters >= 1000) return $"{meters / 1000:F1} km";
        return $"{meters:F0} m";
    }

    private static Color GetScopeColor(ResponseScope scope) => scope switch
    {
        ResponseScope.CheckIn => Color.Info,
        ResponseScope.Neighborhood => Color.Warning,
        ResponseScope.Community => Color.Error,
        ResponseScope.Evacuation => Color.Dark,
        ResponseScope.SilentDuress => Color.Secondary,
        _ => Color.Default
    };

    private static Color GetStatusColor(ResponseStatus status) => status switch
    {
        ResponseStatus.Pending => Color.Default,
        ResponseStatus.Dispatching => Color.Info,
        ResponseStatus.Active => Color.Warning,
        ResponseStatus.Escalated => Color.Error,
        ResponseStatus.Resolved => Color.Success,
        ResponseStatus.Cancelled => Color.Dark,
        ResponseStatus.Expired => Color.Dark,
        _ => Color.Default
    };

    private static Color GetAckStatusColor(AckStatus status) => status switch
    {
        AckStatus.Acknowledged => Color.Info,
        AckStatus.EnRoute => Color.Warning,
        AckStatus.OnScene => Color.Success,
        AckStatus.Declined => Color.Dark,
        AckStatus.TimedOut => Color.Error,
        _ => Color.Default
    };

    private static Color GetEscalationColor(EscalationPolicy policy) => policy switch
    {
        EscalationPolicy.TimedEscalation => Color.Warning,
        EscalationPolicy.Immediate911 => Color.Error,
        EscalationPolicy.Conditional911 => Color.Error,
        EscalationPolicy.FullCascade => Color.Dark,
        _ => Color.Info
    };

    // ── Disposal ─────────────────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        HubService.OnConnectionChanged -= HandleConnectionChanged;

        foreach (var row in _incidents.Where(r => r.IsExpanded))
        {
            try { await HubService.LeaveResponseGroupAsync(row.Request.RequestId); }
            catch { /* best effort */ }
        }
    }

    // ── Row Model ────────────────────────────────────────────────
    public class IncidentRow
    {
        public ResponseRequest Request { get; set; } = default!;
        public int AckCount { get; set; }
        public bool IsExpanded { get; set; }
        public bool LoadingSituation { get; set; }
        public ResponseSituation? Situation { get; set; }
    }
}

<style>
    .page-header {
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
</style>
