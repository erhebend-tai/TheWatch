@page "/milestones"
@rendermode InteractiveServer

<PageTitle>Milestones - TheWatch</PageTitle>

<div class="milestones-container">

    <div class="page-header">
        <h1>Project Milestones</h1>
        <p class="subtitle">Track progress across M0 through M7</p>
    </div>

    <div class="milestones-grid">
        <!-- M0: Foundation -->
        <div class="milestone-card completed">
            <div class="milestone-header">
                <div class="milestone-badge completed">COMPLETED</div>
                <h3>M0: Foundation</h3>
            </div>
            <p class="milestone-desc">Core infrastructure, database schema, deployment setup</p>
            <div class="milestone-stats">
                <div class="stat">
                    <span class="stat-label">Due</span>
                    <span class="stat-value">Jan 15</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Progress</span>
                    <span class="stat-value">100%</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Issues</span>
                    <span class="stat-value">24/24</span>
                </div>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar">
                    <div class="progress-fill completed" style="width: 100%;"></div>
                </div>
            </div>
        </div>

        <!-- M1: Research Consolidated -->
        <div class="milestone-card completed">
            <div class="milestone-header">
                <div class="milestone-badge completed">COMPLETED</div>
                <h3>M1: Research Consolidated</h3>
            </div>
            <p class="milestone-desc">Specification finalization, architecture design, requirements doc</p>
            <div class="milestone-stats">
                <div class="stat">
                    <span class="stat-label">Due</span>
                    <span class="stat-value">Jan 31</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Progress</span>
                    <span class="stat-value">100%</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Issues</span>
                    <span class="stat-value">18/18</span>
                </div>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar">
                    <div class="progress-fill completed" style="width: 100%;"></div>
                </div>
            </div>
        </div>

        <!-- M2: CI/CD Operational -->
        <div class="milestone-card completed">
            <div class="milestone-header">
                <div class="milestone-badge completed">COMPLETED</div>
                <h3>M2: CI/CD Operational</h3>
            </div>
            <p class="milestone-desc">GitHub Actions setup, automated testing, deployment pipelines</p>
            <div class="milestone-stats">
                <div class="stat">
                    <span class="stat-label">Due</span>
                    <span class="stat-value">Feb 14</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Progress</span>
                    <span class="stat-value">100%</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Issues</span>
                    <span class="stat-value">16/16</span>
                </div>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar">
                    <div class="progress-fill completed" style="width: 100%;"></div>
                </div>
            </div>
        </div>

        <!-- M3: Authentication Live -->
        <div class="milestone-card in-progress">
            <div class="milestone-header">
                <div class="milestone-badge in-progress">IN PROGRESS</div>
                <h3>M3: Authentication Live</h3>
            </div>
            <p class="milestone-desc">Login/signup flows, password reset, biometric integration</p>
            <div class="milestone-stats">
                <div class="stat">
                    <span class="stat-label">Due</span>
                    <span class="stat-value">Mar 7</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Progress</span>
                    <span class="stat-value">78%</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Issues</span>
                    <span class="stat-value">21/27</span>
                </div>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar">
                    <div class="progress-fill in-progress" style="width: 78%;"></div>
                </div>
            </div>
        </div>

        <!-- M4: Emergency Pipeline -->
        <div class="milestone-card pending">
            <div class="milestone-header">
                <div class="milestone-badge pending">PENDING</div>
                <h3>M4: Emergency Pipeline</h3>
            </div>
            <p class="milestone-desc">SOS alerts, responder dispatch, real-time tracking, geofencing</p>
            <div class="milestone-stats">
                <div class="stat">
                    <span class="stat-label">Due</span>
                    <span class="stat-value">Apr 4</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Progress</span>
                    <span class="stat-value">0%</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Issues</span>
                    <span class="stat-value">0/32</span>
                </div>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar">
                    <div class="progress-fill pending" style="width: 0%;"></div>
                </div>
            </div>
        </div>

        <!-- M5: Full Feature Set -->
        <div class="milestone-card pending">
            <div class="milestone-header">
                <div class="milestone-badge pending">PENDING</div>
                <h3>M5: Full Feature Set</h3>
            </div>
            <p class="milestone-desc">Profile mgmt, permissions, history, volunteering, contacts</p>
            <div class="milestone-stats">
                <div class="stat">
                    <span class="stat-label">Due</span>
                    <span class="stat-value">May 2</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Progress</span>
                    <span class="stat-value">0%</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Issues</span>
                    <span class="stat-value">0/28</span>
                </div>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar">
                    <div class="progress-fill pending" style="width: 0%;"></div>
                </div>
            </div>
        </div>

        <!-- M6: Release Candidate -->
        <div class="milestone-card pending">
            <div class="milestone-header">
                <div class="milestone-badge pending">PENDING</div>
                <h3>M6: Release Candidate</h3>
            </div>
            <p class="milestone-desc">Performance tuning, security hardening, bug fixes, QA</p>
            <div class="milestone-stats">
                <div class="stat">
                    <span class="stat-label">Due</span>
                    <span class="stat-value">Jun 13</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Progress</span>
                    <span class="stat-value">0%</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Issues</span>
                    <span class="stat-value">0/22</span>
                </div>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar">
                    <div class="progress-fill pending" style="width: 0%;"></div>
                </div>
            </div>
        </div>

        <!-- M7: v1.0.0 Launch -->
        <div class="milestone-card pending">
            <div class="milestone-header">
                <div class="milestone-badge pending">PENDING</div>
                <h3>M7: v1.0.0 Launch</h3>
            </div>
            <p class="milestone-desc">Production deployment, monitoring setup, post-launch support</p>
            <div class="milestone-stats">
                <div class="stat">
                    <span class="stat-label">Due</span>
                    <span class="stat-value">Jul 1</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Progress</span>
                    <span class="stat-value">0%</span>
                </div>
                <div class="stat">
                    <span class="stat-label">Issues</span>
                    <span class="stat-value">0/8</span>
                </div>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar">
                    <div class="progress-fill pending" style="width: 0%;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Burndown Section -->
    <div class="analytics-section">
        <h2>Burndown Chart</h2>
        <div class="burndown-container">
            <div class="burndown-chart">
                <svg viewBox="0 0 700 300" class="burndown-svg">
                    <!-- Grid lines -->
                    <line x1="60" y1="10" x2="60" y2="260" stroke="#e0e0e0" stroke-width="1" />
                    <line x1="60" y1="260" x2="680" y2="260" stroke="#e0e0e0" stroke-width="1" />

                    <!-- Grid horizontal lines -->
                    <line x1="50" y1="220" x2="680" y2="220" stroke="#f0f0f0" stroke-width="1" />
                    <line x1="50" y1="180" x2="680" y2="180" stroke="#f0f0f0" stroke-width="1" />
                    <line x1="50" y1="140" x2="680" y2="140" stroke="#f0f0f0" stroke-width="1" />
                    <line x1="50" y1="100" x2="680" y2="100" stroke="#f0f0f0" stroke-width="1" />
                    <line x1="50" y1="60" x2="680" y2="60" stroke="#f0f0f0" stroke-width="1" />

                    <!-- Y-axis labels -->
                    <text x="35" y="265" font-size="11" fill="#999">0</text>
                    <text x="25" y="225" font-size="11" fill="#999">50</text>
                    <text x="25" y="185" font-size="11" fill="#999">100</text>
                    <text x="25" y="145" font-size="11" fill="#999">150</text>
                    <text x="25" y="105" font-size="11" fill="#999">200</text>
                    <text x="25" y="65" font-size="11" fill="#999">250</text>

                    <!-- Burndown line (blue) -->
                    <polyline points="60,50 120,100 180,130 240,160 300,180 360,200 420,220 480,235 540,245 600,255 660,260"
                              stroke="#0066cc" stroke-width="2" fill="none" />

                    <!-- Ideal line (gray dashed) -->
                    <line x1="60" y1="50" x2="660" y2="260" stroke="#ccc" stroke-width="2" stroke-dasharray="4,4" />

                    <!-- Data points -->
                    <circle cx="60" cy="50" r="4" fill="#0066cc" />
                    <circle cx="120" cy="100" r="4" fill="#0066cc" />
                    <circle cx="180" cy="130" r="4" fill="#0066cc" />
                    <circle cx="240" cy="160" r="4" fill="#0066cc" />
                    <circle cx="300" cy="180" r="4" fill="#0066cc" />
                    <circle cx="360" cy="200" r="4" fill="#0066cc" />
                    <circle cx="420" cy="220" r="4" fill="#0066cc" />
                    <circle cx="480" cy="235" r="4" fill="#0066cc" />
                    <circle cx="540" cy="245" r="4" fill="#0066cc" />
                    <circle cx="600" cy="255" r="4" fill="#0066cc" />
                    <circle cx="660" cy="260" r="4" fill="#0066cc" />

                    <!-- X-axis labels -->
                    <text x="55" y="280" font-size="11" fill="#999">W1</text>
                    <text x="115" y="280" font-size="11" fill="#999">W2</text>
                    <text x="175" y="280" font-size="11" fill="#999">W3</text>
                    <text x="235" y="280" font-size="11" fill="#999">W4</text>
                    <text x="295" y="280" font-size="11" fill="#999">W5</text>
                    <text x="355" y="280" font-size="11" fill="#999">W6</text>
                </svg>
            </div>
            <div class="burndown-legend">
                <div class="legend-item">
                    <div class="legend-line actual"></div>
                    <span>Actual Progress</span>
                </div>
                <div class="legend-item">
                    <div class="legend-line ideal"></div>
                    <span>Ideal Trajectory</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Issues by Agent Section -->
    <div class="analytics-section">
        <h2>Issues by Agent</h2>
        <div class="agent-breakdown">
            <div class="agent-row">
                <div class="agent-name">Claude Code</div>
                <div class="agent-bars">
                    <div class="bar-group">
                        <div class="bar completed" style="width: 58%;"></div>
                        <div class="bar remaining" style="width: 42%;"></div>
                    </div>
                    <span class="bar-label">58/100</span>
                </div>
            </div>

            <div class="agent-row">
                <div class="agent-name">Gemini Pro</div>
                <div class="agent-bars">
                    <div class="bar-group">
                        <div class="bar completed" style="width: 45%;"></div>
                        <div class="bar remaining" style="width: 55%;"></div>
                    </div>
                    <span class="bar-label">45/100</span>
                </div>
            </div>

            <div class="agent-row">
                <div class="agent-name">Azure OpenAI</div>
                <div class="agent-bars">
                    <div class="bar-group">
                        <div class="bar completed" style="width: 62%;"></div>
                        <div class="bar remaining" style="width: 38%;"></div>
                    </div>
                    <span class="bar-label">62/100</span>
                </div>
            </div>

            <div class="agent-row">
                <div class="agent-name">Copilot</div>
                <div class="agent-bars">
                    <div class="bar-group">
                        <div class="bar completed" style="width: 51%;"></div>
                        <div class="bar remaining" style="width: 49%;"></div>
                    </div>
                    <span class="bar-label">51/100</span>
                </div>
            </div>

            <div class="agent-row">
                <div class="agent-name">JetBrains AI</div>
                <div class="agent-bars">
                    <div class="bar-group">
                        <div class="bar completed" style="width: 39%;"></div>
                        <div class="bar remaining" style="width: 61%;"></div>
                    </div>
                    <span class="bar-label">39/100</span>
                </div>
            </div>

            <div class="agent-row">
                <div class="agent-name">Junie</div>
                <div class="agent-bars">
                    <div class="bar-group">
                        <div class="bar completed" style="width: 72%;"></div>
                        <div class="bar remaining" style="width: 28%;"></div>
                    </div>
                    <span class="bar-label">72/100</span>
                </div>
            </div>

            <div class="agent-row">
                <div class="agent-name">Barton</div>
                <div class="agent-bars">
                    <div class="bar-group">
                        <div class="bar completed" style="width: 48%;"></div>
                        <div class="bar remaining" style="width: 52%;"></div>
                    </div>
                    <span class="bar-label">48/100</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Blocked Items Section -->
    <div class="analytics-section">
        <h2>Blocked Items</h2>
        <div class="blocked-items">
            <div class="blocked-item">
                <div class="blocked-header">
                    <span class="blocked-id">#427</span>
                    <span class="blocked-title">Implement hardware SOS button integration</span>
                    <span class="blocked-severity">Critical</span>
                </div>
                <div class="blocked-reason">
                    <strong>Blocker:</strong> Awaiting device firmware API documentation from hardware vendor (ETA: Mar 28)
                </div>
                <div class="blocked-meta">
                    <span>Assigned: Claude Code</span>
                    <span>Blocked since: Mar 20</span>
                </div>
            </div>

            <div class="blocked-item">
                <div class="blocked-header">
                    <span class="blocked-id">#389</span>
                    <span class="blocked-title">GPS accuracy testing in urban canyons</span>
                    <span class="blocked-severity">High</span>
                </div>
                <div class="blocked-reason">
                    <strong>Blocker:</strong> Requires high-precision test environment setup; waiting on lab facility approval (ETA: Apr 1)
                </div>
                <div class="blocked-meta">
                    <span>Assigned: Junie</span>
                    <span>Blocked since: Mar 18</span>
                </div>
            </div>

            <div class="blocked-item">
                <div class="blocked-header">
                    <span class="blocked-id">#401</span>
                    <span class="blocked-title">Wearable data synchronization with Apple HealthKit</span>
                    <span class="blocked-severity">High</span>
                </div>
                <div class="blocked-reason">
                    <strong>Blocker:</strong> Depends on M4 (Emergency Pipeline) completion for event correlation logic
                </div>
                <div class="blocked-meta">
                    <span>Assigned: Azure OpenAI</span>
                    <span>Blocked since: Mar 15</span>
                </div>
            </div>
        </div>
    </div>

</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask;
    }
}

<style>
    .milestones-container {
        margin-left: 0;
        padding: 40px;
        background: linear-gradient(135deg, #f5f7fa 0%, #e9eef5 100%);
        min-height: 100vh;
    }

    .page-header {
        margin-bottom: 40px;
    }

    .page-header h1 {
        margin: 0 0 8px 0;
        font-size: 32px;
        color: #1b2a4a;
        font-weight: 800;
    }

    .page-header .subtitle {
        margin: 0;
        font-size: 16px;
        color: #666;
    }

    .milestones-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .milestone-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: all 0.2s ease;
        border-left: 4px solid #ccc;
    }

    .milestone-card.completed {
        border-left-color: #28a745;
    }

    .milestone-card.in-progress {
        border-left-color: #0066cc;
    }

    .milestone-card.pending {
        border-left-color: #999;
    }

    .milestone-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
        transform: translateY(-2px);
    }

    .milestone-header {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-bottom: 12px;
    }

    .milestone-header h3 {
        margin: 0;
        font-size: 16px;
        color: #1b2a4a;
        font-weight: 700;
    }

    .milestone-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 4px 8px;
        border-radius: 4px;
        white-space: nowrap;
    }

    .milestone-badge.completed {
        background: #d4edda;
        color: #155724;
    }

    .milestone-badge.in-progress {
        background: #d1ecf1;
        color: #0c5460;
    }

    .milestone-badge.pending {
        background: #e2e3e5;
        color: #383d41;
    }

    .milestone-desc {
        margin: 0 0 16px 0;
        font-size: 13px;
        color: #666;
        line-height: 1.4;
    }

    .milestone-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 16px;
        padding-bottom: 16px;
        border-bottom: 1px solid #f0f0f0;
    }

    .stat {
        text-align: center;
    }

    .stat-label {
        display: block;
        font-size: 11px;
        color: #999;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .stat-value {
        display: block;
        font-size: 16px;
        color: #1b2a4a;
        font-weight: 700;
    }

    .progress-bar-container {
        position: relative;
    }

    .progress-bar {
        width: 100%;
        height: 6px;
        background: #e0e0e0;
        border-radius: 3px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.3s ease;
    }

    .progress-fill.completed {
        background: #28a745;
    }

    .progress-fill.in-progress {
        background: #0066cc;
    }

    .progress-fill.pending {
        background: #ccc;
    }

    /* Analytics Sections */
    .analytics-section {
        background: white;
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 30px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .analytics-section h2 {
        margin: 0 0 24px 0;
        font-size: 20px;
        color: #1b2a4a;
        font-weight: 700;
    }

    /* Burndown Chart */
    .burndown-container {
        display: flex;
        gap: 24px;
        align-items: flex-start;
    }

    .burndown-chart {
        flex: 1;
        min-height: 320px;
        background: #fafafa;
        border-radius: 8px;
        padding: 16px;
    }

    .burndown-svg {
        width: 100%;
        height: 100%;
    }

    .burndown-legend {
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-width: 180px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #333;
    }

    .legend-line {
        width: 24px;
        height: 2px;
    }

    .legend-line.actual {
        background: #0066cc;
    }

    .legend-line.ideal {
        background: #ccc;
        background-image: linear-gradient(90deg, #ccc 50%, transparent 50%);
        background-size: 4px 2px;
    }

    /* Agent Breakdown */
    .agent-breakdown {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .agent-row {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .agent-name {
        min-width: 120px;
        font-size: 13px;
        font-weight: 600;
        color: #1b2a4a;
    }

    .agent-bars {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .bar-group {
        flex: 1;
        display: flex;
        height: 24px;
        background: #f0f0f0;
        border-radius: 4px;
        overflow: hidden;
    }

    .bar {
        height: 100%;
        transition: all 0.3s ease;
    }

    .bar.completed {
        background: #28a745;
    }

    .bar.remaining {
        background: #e8e8e8;
    }

    .bar-label {
        min-width: 60px;
        font-size: 12px;
        color: #666;
        font-weight: 600;
        text-align: right;
    }

    /* Blocked Items */
    .blocked-items {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .blocked-item {
        border: 1px solid #ffc107;
        border-left: 4px solid #ffc107;
        border-radius: 8px;
        padding: 16px;
        background: #fffbf0;
    }

    .blocked-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .blocked-id {
        font-size: 12px;
        font-weight: 700;
        color: #999;
    }

    .blocked-title {
        flex: 1;
        font-size: 14px;
        font-weight: 600;
        color: #1b2a4a;
    }

    .blocked-severity {
        font-size: 11px;
        font-weight: 700;
        padding: 4px 8px;
        border-radius: 4px;
        background: #ffc107;
        color: #333;
    }

    .blocked-reason {
        font-size: 13px;
        color: #666;
        margin-bottom: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(255, 193, 7, 0.3);
    }

    .blocked-reason strong {
        color: #1b2a4a;
    }

    .blocked-meta {
        display: flex;
        gap: 24px;
        font-size: 12px;
        color: #999;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .milestones-grid {
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        }

        .burndown-container {
