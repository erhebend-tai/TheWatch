@page "/builds"
@using TheWatch.Shared.Dtos
@using TheWatch.Shared.Enums

<PageTitle>Builds - TheWatch</PageTitle>

<div class="builds-container">

    <div class="page-header">
        <h1>Build Pipeline</h1>
        <p class="subtitle">Continuous integration and deployment status</p>
    </div>

    <div class="builds-stats">
        <div class="stat-card">
            <div class="stat-icon">✓</div>
            <div class="stat-info">
                <div class="stat-label">Successful</div>
                <div class="stat-value">44</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">⚠</div>
            <div class="stat-info">
                <div class="stat-label">Warnings</div>
                <div class="stat-value">3</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">✕</div>
            <div class="stat-info">
                <div class="stat-label">Failed</div>
                <div class="stat-value">0</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">⏱</div>
            <div class="stat-info">
                <div class="stat-label">Avg Duration</div>
                <div class="stat-value">3m 24s</div>
            </div>
        </div>
    </div>

    <div class="builds-list">

        <div class="build-item success">
            <div class="build-status-icon">✓</div>
            <div class="build-info">
                <div class="build-title">Release Build v2.1.0</div>
                <div class="build-details">
                    <span class="badge">Multi-Platform</span>
                    <span class="badge">Release</span>
                </div>
                <div class="build-description">All platforms compiled and packaged successfully</div>
            </div>
            <div class="build-meta">
                <div class="build-time">2h ago</div>
                <div class="build-duration">3m 42s</div>
            </div>
        </div>

        <div class="build-item success">
            <div class="build-status-icon">✓</div>
            <div class="build-info">
                <div class="build-title">Dashboard Web Server</div>
                <div class="build-details">
                    <span class="badge">Web</span>
                    <span class="badge">Blazor</span>
                </div>
                <div class="build-description">Web dashboard deployed to staging environment</div>
            </div>
            <div class="build-meta">
                <div class="build-time">4h ago</div>
                <div class="build-duration">1m 58s</div>
            </div>
        </div>

        <div class="build-item warning">
            <div class="build-status-icon">⚠</div>
            <div class="build-info">
                <div class="build-title">Mobile Build (Android)</div>
                <div class="build-details">
                    <span class="badge">Mobile</span>
                    <span class="badge">Android</span>
                </div>
                <div class="build-description">Build completed with 2 warnings in dependency analysis</div>
            </div>
            <div class="build-meta">
                <div class="build-time">6h ago</div>
                <div class="build-duration">4m 15s</div>
            </div>
        </div>

        <div class="build-item success">
            <div class="build-status-icon">✓</div>
            <div class="build-info">
                <div class="build-title">API Microservices</div>
                <div class="build-details">
                    <span class="badge">API</span>
                    <span class="badge">.NET 9</span>
                </div>
                <div class="build-description">All API endpoints built and containerized successfully</div>
            </div>
            <div class="build-meta">
                <div class="build-time">8h ago</div>
                <div class="build-duration">2m 31s</div>
            </div>
        </div>

        <div class="build-item success">
            <div class="build-status-icon">✓</div>
            <div class="build-info">
                <div class="build-title">Mobile Build (iOS)</div>
                <div class="build-details">
                    <span class="badge">Mobile</span>
                    <span class="badge">iOS</span>
                </div>
                <div class="build-description">iOS build signed and ready for TestFlight submission</div>
            </div>
            <div class="build-meta">
                <div class="build-time">1d ago</div>
                <div class="build-duration">5m 03s</div>
            </div>
        </div>

        <div class="build-item success">
            <div class="build-status-icon">✓</div>
            <div class="build-info">
                <div class="build-title">Test Suite Execution</div>
                <div class="build-details">
                    <span class="badge">Testing</span>
                    <span class="badge">xUnit</span>
                </div>
                <div class="build-description">1,247 unit tests passed, 0 failures</div>
            </div>
            <div class="build-meta">
                <div class="build-time">1d ago</div>
                <div class="build-duration">8m 44s</div>
            </div>
        </div>

        <div class="build-item success">
            <div class="build-status-icon">✓</div>
            <div class="build-info">
                <div class="build-title">Code Analysis & Quality</div>
                <div class="build-details">
                    <span class="badge">Analysis</span>
                    <span class="badge">SonarQube</span>
                </div>
                <div class="build-description">Code quality metrics: A grade, 0 critical issues</div>
            </div>
            <div class="build-meta">
                <div class="build-time">2d ago</div>
                <div class="build-duration">3m 12s</div>
            </div>
        </div>

        <div class="build-item success">
            <div class="build-status-icon">✓</div>
            <div class="build-info">
                <div class="build-title">Production Deployment</div>
                <div class="build-details">
                    <span class="badge">Deployment</span>
                    <span class="badge">Azure</span>
                </div>
                <div class="build-description">v2.0.3 successfully deployed to production</div>
            </div>
            <div class="build-meta">
                <div class="build-time">3d ago</div>
                <div class="build-duration">2m 18s</div>
            </div>
        </div>

    </div>

</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Load build data
        await Task.CompletedTask;
    }
}
