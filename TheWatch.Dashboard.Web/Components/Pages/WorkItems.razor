                    <td class="col-status"><span class="badge completed">Completed</span></td>
                    <td class="col-platform">Mobile</td>
                    <td class="col-milestone">M2</td>
                    <td class="col-assigned">Team C</td>
                    <td class="col-due">2026-03-20</td>
