@page "/workitems"
@using TheWatch.Shared.Dtos
@using TheWatch.Shared.Enums

<PageTitle>Work Items - TheWatch</PageTitle>

<div class="workitems-container">

    <div class="page-header">
        <h1>Work Items</h1>
        <p class="subtitle">Track tasks across all platforms and milestones</p>
    </div>

    <div class="filters-bar">
        <div class="filter-group">
            <label>Status:</label>
            <select class="filter-select">
                <option>All</option>
                <option>Active</option>
                <option>Completed</option>
                <option>Blocked</option>
            </select>
        </div>
        <div class="filter-group">
            <label>Platform:</label>
            <select class="filter-select">
                <option>All</option>
                <option>Web</option>
                <option>Mobile</option>
                <option>API</option>
                <option>Infrastructure</option>
            </select>
        </div>
        <div class="filter-group">
            <label>Milestone:</label>
            <select class="filter-select">
                <option>All</option>
                <option>M0</option>
                <option>M1</option>
                <option>M2</option>
                <option>M3</option>
            </select>
        </div>
    </div>

    <div class="workitems-table">
        <table>
            <thead>
                <tr>
                    <th class="col-id">ID</th>
                    <th class="col-title">Title</th>
                    <th class="col-status">Status</th>
                    <th class="col-platform">Platform</th>
                    <th class="col-milestone">Milestone</th>
                    <th class="col-assigned">Assigned</th>
                    <th class="col-due">Due Date</th>
                </tr>
            </thead>
            <tbody>
                <tr class="item-active">
                    <td class="col-id">WI-0001</td>
                    <td class="col-title">
                        <div class="title-content">
                            <span class="title-text">Dashboard Grid Layout</span>
                            <span class="title-priority high">HIGH</span>
                        </div>
                    </td>
                    <td class="col-status"><span class="badge active">In Progress</span></td>
                    <td class="col-platform">Web</td>
                    <td class="col-milestone">M2</td>
                    <td class="col-assigned">Team A</td>
                    <td class="col-due">2026-03-28</td>
                </tr>

                <tr class="item-active">
                    <td class="col-id">WI-0002</td>
